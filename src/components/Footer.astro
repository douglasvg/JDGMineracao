---
import { MapPin, Phone, Mail, Building2, Clock } from 'lucide-react';
import jdgLogo from '../../images/JDG Mineracao Logo SVG.svg';
---

<footer class="bg-slate-900 text-slate-300">
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <!-- Company Info -->
      <div class="lg:col-span-1 space-y-6">
        <a href="/" class="flex items-center space-x-3 group">
          <img
            src={jdgLogo.src}
            alt="JDG Mineração"
            class="h-12 w-auto object-contain transition-transform group-hover:scale-[1.02] brightness-0 invert opacity-90"
            loading="eager"
            decoding="async"
          />
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-xs">
          Fornecedora de areia de qualidade para construtoras, empreiteiras e obras em Santa Catarina.
        </p>
        <div class="space-y-2">
          <p class="text-sm text-white/75 inline-flex items-start gap-2">
            <MapPin className="w-4 h-4 mt-0.5 shrink-0" />
            <span>Br 153, s/n, Sala 01, Bairro São Gabriel, União da Vitória, PR, CEP 84.602-450</span>
          </p>
          <p class="text-sm text-white/75 inline-flex items-center gap-2">
            <Phone className="w-4 h-4 shrink-0" />
            <span>(49)000000000</span>
          </p>
          <p class="text-sm text-white/75 inline-flex items-center gap-2">
            <Mail className="w-4 h-4 shrink-0" />
            <span>vendas@jdgmineracao.com.br</span>
          </p>
          <p class="text-sm text-white/75 inline-flex items-center gap-2">
            <Building2 className="w-4 h-4 shrink-0" />
            <span>CNPJ: 53.748.938/0001-50</span>
          </p>
          <p class="text-sm text-white/75 inline-flex items-center gap-2">
            <Clock className="w-4 h-4 shrink-0" />
            <span>Horário: Seg-Sex, 07h às 17h</span>
          </p>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          NAVEGAÇÃO
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/home" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Home
            </a>
          </li>
          <li>
            <a href="/sobre" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Sobre Nós
            </a>
          </li>
          <li>
            <a href="/produtos" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Produtos
            </a>
          </li>
          <li>
            <a href="/localidades" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Localidades
            </a>
          </li>
          <li>
            <a href="/contato" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Contato
            </a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          NOSSOS PRODUTOS
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/produtos" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Areia Fina
            </a>
          </li>
          <li>
            <a href="/produtos" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Areia Média
            </a>
          </li>
          <li>
            <a href="/produtos" class="text-sm text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Areia Grossa
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white mb-6">
          ATENDIMENTO
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="/contato" class="text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Solicitar Orçamento
            </a>
          </li>
          <li>
            <a href="/localidades" class="text-slate-400 hover:text-[#393e92] transition-colors inline-flex items-center group">
              <span class="w-0 group-hover:w-2 h-0.5 bg-[#393e92] transition-all mr-0 group-hover:mr-2"></span>
              Nossa Localização
            </a>
          </li>
        </ul>
        
        <div class="mt-8">
          <a
            href="/contato"
            class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-[#393e92] hover:bg-[#2e3275] rounded-lg shadow-lg hover:shadow-xl transition-all"
          >
            Solicitar Orçamento
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-slate-800">
      <div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
        <p class="text-sm text-slate-400">
          &copy; {new Date().getFullYear()} JDG Mineração. Todos os direitos reservados.
        </p>
        <div class="flex items-center space-x-6 text-sm">
          <a href="/" class="text-slate-400 hover:text-[#393e92] transition-colors">
            Política de Privacidade
          </a>
          <span class="text-slate-700">•</span>
          <a href="/" class="text-slate-400 hover:text-[#393e92] transition-colors">
            Termos de Uso
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
