---
import { NAVIGATION } from '@config/site';
import MobileMenu from '@components/react/MobileMenu';
import jdgLogo from '../../images/JDG Mineracao Logo SVG.svg';

const { currentPathname } = Astro.props;
const isActiveLink = (href: string) : boolean => { return href === currentPathname; }

---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur-md shadow-sm">
  <nav class="container mx-auto flex h-20 items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <div class="flex items-center">
      <a href="/" class="flex items-center group">
        <img
          src={jdgLogo.src}
          alt="JDG Mineracao"
          class="h-12 w-auto object-contain transition-transform group-hover:scale-[1.02]"
          loading="eager"
          decoding="async"
        />
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex lg:items-center lg:space-x-1">
      {NAVIGATION.map((item) => {
        const isActive = isActiveLink(item.href);
        return (
        <a
          href={item.href}
          class={`px-4 py-2 text-sm font-medium text-slate-700 hover:text-[#393e92] hover:bg-[#eeeef7] rounded-lg transition-all relative group ${isActive ? 'nav-active' : ''}`}
        >
          {item.name}
        </a>
      );
      })}
    </div>

    <!-- CTA Button -->
    <div class="hidden lg:flex lg:items-center lg:space-x-4">
      <a
        href="/contato"
        class="inline-flex items-center px-6 py-2.5 text-sm font-semibold text-white bg-[#393e92] hover:bg-[#2e3275] rounded-lg shadow-md hover:shadow-lg transition-all"
      >
        Faça um Orçamento
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <MobileMenu client:idle />
  </nav>
</header>
