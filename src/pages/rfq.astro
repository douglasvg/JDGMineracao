---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Card from '@components/ui/Card.astro';
import RFQForm from '@components/react/RFQForm';
import { Image } from 'astro:assets';
import { FileText, Clock, Shield, CheckCircle2, Phone, Mail, MessageCircle, Award, TrendingUp, Users, MapPin } from 'lucide-react';
import areiaTexturaImg from '../../images/areia-textura.png';
---

<BaseLayout title="Contato | Solicite seu Orçamento">
  <!-- Hero Section with Professional Image -->
  <section class="relative h-[500px] md:h-[600px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image
        src={areiaTexturaImg}
        alt="Textura de areia"
        class="w-full h-full object-cover"
        width={1600}
        height={900}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/80 via-slate-900/70 to-slate-900/60"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-[#393e92] text-white text-sm font-semibold rounded-full shadow-lg animate-fadeInUp">
          <FileText className="w-4 h-4 mr-2" />
          Fale Conosco
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp" style="animation-delay: 0.1s">
          Solicite seu <span class="text-white">Orçamento</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.2s">
          Preencha o formulário e entraremos em contato rapidamente. Atendemos construtoras,
          empreiteiras e obras de todos os portes.
        </p>

        <!-- Quick Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-8 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.3s">
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">24h</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">Resposta em até 24h</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">3</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">3 Tipos de Areia</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">100%</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">Areia Classificada</div>
          </div>
          <div class="group">
            <div class="text-3xl md:text-4xl font-bold text-white mb-1">SC</div>
            <div class="text-sm text-slate-300 group-hover:text-teal-300 transition-colors">Santa Catarina</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Wave separator -->
    <!-- <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div> -->
  </section>

  <!-- Main Form Section -->
  <Section background="gray">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Form -->
      <div class="lg:col-span-2">
        <Card>
          <RFQForm client:load />
        </Card>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Contact Info Card -->
        <Card class="bg-linear-to-br from-[#eeeef7] to-teal-50 border-[#393e92]/20">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-[#393e92] flex items-center justify-center mr-3">
              <Phone className="w-5 h-5 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Entre em Contato</h3>
          </div>
          <div class="space-y-4 text-sm">
            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-[#eeeef7] flex items-center justify-center shrink-0">
                <Phone className="w-5 h-5 text-[#393e92]" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Telefone / WhatsApp</div>
                <div class="text-gray-600 font-medium">(49) 000000000</div>
                <div class="text-gray-500 text-xs">Seg–Sex, 07h às 17h</div>
              </div>
            </div>

            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-teal-100 flex items-center justify-center shrink-0">
                <Mail className="w-5 h-5 text-teal-600" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">E-mail</div>
                <div class="text-gray-600 font-medium">vendas@jdgmineracao.com.br</div>
                <div class="text-gray-500 text-xs">Resposta em até 24 horas</div>
              </div>
            </div>

            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center shrink-0">
                <MapPin className="w-5 h-5 text-green-600" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Endereço</div>
                <div class="text-gray-600 font-medium">BR 153, s/n, Sala 01</div>
                <div class="text-gray-500 text-xs">Bairro São Gabriel, União da Vitória – PR</div>
                <div class="text-gray-500 text-xs">CEP 84.602-450</div>
              </div>
            </div>

            <div class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
                <Clock className="w-5 h-5 text-amber-600" />
              </div>
              <div>
                <div class="font-semibold text-gray-900">Horário de Funcionamento</div>
                <div class="text-gray-600 font-medium">Segunda a Sexta</div>
                <div class="text-gray-500 text-xs">07h às 17h</div>
              </div>
            </div>
          </div>

          <a
            href="https://wa.me/5549000000000"
            target="_blank"
            rel="noreferrer"
            class="mt-4 inline-flex w-full items-center justify-center rounded-lg bg-[#25D366] px-4 py-3 font-semibold text-white transition-colors hover:bg-[#1faa52]"
          >
            <MessageCircle className="mr-2 h-5 w-5" />
            Chamar no WhatsApp
          </a>
        </Card>

        <!-- What to Expect Card -->
        <Card class="bg-linear-to-br from-primary-50 via-[#eeeef7] to-secondary-50 border-primary-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-[#393e92] flex items-center justify-center mr-3">
              <Clock className="w-5 h-5 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Como Funciona</h3>
          </div>
          <ol class="space-y-4 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-[#393e92] text-white flex items-center justify-center font-bold text-sm shadow-md">1</span>
              <div>
                <span class="text-gray-900 font-semibold block">Recebemos sua solicitação</span>
                <span class="text-gray-600">Analisamos sua necessidade de areia e volume</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-linear-to-br from-teal-600 to-teal-700 text-white flex items-center justify-center font-bold text-sm shadow-md">2</span>
              <div>
                <span class="text-gray-900 font-semibold block">Entramos em contato</span>
                <span class="text-gray-600">Nossa equipe retorna em até 2 dias úteis</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-linear-to-br from-orange-500 to-amber-600 text-white flex items-center justify-center font-bold text-sm shadow-md">3</span>
              <div>
                <span class="text-gray-900 font-semibold block">Enviamos o orçamento</span>
                <span class="text-gray-600">Proposta personalizada para sua obra</span>
              </div>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <span class="shrink-0 w-8 h-8 rounded-full bg-linear-to-br from-purple-600 to-purple-700 text-white flex items-center justify-center font-bold text-sm shadow-md">4</span>
              <div>
                <span class="text-gray-900 font-semibold block">Produto disponível</span>
                <span class="text-gray-600">Areia pronta para retirada ou avaliamos entrega</span>
              </div>
            </li>
          </ol>
        </Card>

        <!-- Trust Indicators -->
        <Card class="bg-linear-to-br from-slate-50 to-gray-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-linear-to-br from-green-600 to-emerald-600 flex items-center justify-center mr-3">
              <Award className="w-5 h-5 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Por que a JDG?</h3>
          </div>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-green-100 flex items-center justify-center shrink-0">
                <TrendingUp className="w-4 h-4 text-green-600" />
              </div>
              <span class="text-gray-700 pt-1">Areia classificada e de qualidade</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-[#eeeef7] flex items-center justify-center shrink-0">
                <CheckCircle2 className="w-4 h-4 text-[#393e92]" />
              </div>
              <span class="text-gray-700 pt-1">3 granulometrias disponíveis</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center shrink-0">
                <Shield className="w-4 h-4 text-purple-600" />
              </div>
              <span class="text-gray-700 pt-1">Atendimento ágil e sem burocracia</span>
            </li>
            <li class="flex items-start space-x-3 p-3 bg-white rounded-lg hover:shadow-md transition-shadow">
              <div class="w-8 h-8 rounded-lg bg-orange-100 flex items-center justify-center shrink-0">
                <Clock className="w-4 h-4 text-orange-600" />
              </div>
              <span class="text-gray-700 pt-1">Retirada rápida e organizada</span>
            </li>
          </ul>
        </Card>

        <Card class="bg-linear-to-br from-slate-50 to-gray-50 border-slate-200">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 rounded-lg bg-[#393e92] flex items-center justify-center mr-3">
              <MapPin className="w-5 h-5 text-white" />
            </div>
            <h3 class="text-xl font-bold text-gray-900">Nossa Localização</h3>
          </div>
          <iframe
            src="https://www.google.com/maps?q=-26.218424,-51.131875&z=16&output=embed"
            width="100%"
            height="250"
            style="border:0; border-radius: 8px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </Card>
      </div>
    </div>
  </Section>

  <!-- Trust & Success Section -->
  <Section background="white">
    <div class="text-center mb-12">
      <div class="inline-block px-4 py-2 mb-4 bg-[#eeeef7] text-[#393e92] text-sm font-semibold rounded-full">
        JDG Mineração
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Qualidade e Agilidade para <span class="text-[#393e92]">Sua Obra</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Atendimento especializado para construtoras, empreiteiras e obras que precisam de fornecimento confiável.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Feature 1 -->
      <Card class="text-center hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-full bg-[#393e92] flex items-center justify-center mx-auto mb-4">
          <Shield className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Areia de Qualidade</h3>
        <p class="text-gray-600">
          Matéria-prima classificada e testada para garantir o melhor desempenho na sua obra.
        </p>
      </Card>

      <!-- Feature 2 -->
      <Card class="text-center hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-full bg-linear-to-br from-green-600 to-emerald-600 flex items-center justify-center mx-auto mb-4">
          <TrendingUp className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Atendimento Rápido</h3>
        <p class="text-gray-600">
          Responderemos em até 24 horas e disponibilizamos o produto com agilidade.
        </p>
      </Card>

      <!-- Feature 3 -->
      <Card class="text-center hover:shadow-xl transition-all duration-300">
        <div class="w-16 h-16 rounded-full bg-linear-to-br from-purple-600 to-pink-600 flex items-center justify-center mx-auto mb-4">
          <Users className="w-8 h-8 text-white" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Suporte Especializado</h3>
        <p class="text-gray-600">
          Nossa equipe está preparada para auxiliar na escolha da granulometria certa para cada etapa da sua obra.
        </p>
      </Card>
    </div>

    <!-- Visual Showcase -->
    <div class="relative rounded-2xl overflow-hidden shadow-2xl">
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1519750783826-e2420f4d687f?w=1600&q=80"
          alt="Operação de mineração e abastecimento de obra"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-linear-to-r from-slate-900/90 via-[#393e92]/80 to-slate-900/70"></div>
      </div>
      <div class="relative z-10 p-12 md:p-16 text-center text-white">
        <h3 class="text-3xl md:text-4xl font-bold mb-4">
          Pronto para Abastecer sua Obra?
        </h3>
        <p class="text-xl text-slate-200 mb-8 max-w-2xl mx-auto">
          Entre em contato agora e receba um orçamento personalizado para areia fina, média ou grossa.
        </p>
        <a 
          href="#rfq-form" 
          class="inline-flex items-center px-8 py-4 bg-[#393e92] hover:bg-[#2e3275] text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-200"
        >
          Solicitar Orçamento Agora
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>

